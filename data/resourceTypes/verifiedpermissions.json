{
  "policy-store": {
    "key": "policy-store",
    "arn": "arn:${Partition}:verifiedpermissions::${Account}:policy-store/${PolicyStoreId}",
    "conditionKeys": [
      "aws:ResourceTag/${TagKey}"
    ]
  },
  "policy-store-alias": {
    "key": "policy-store-alias",
    "arn": "arn:${Partition}:verifiedpermissions:${Region}:${Account}:policy-store-alias/${AliasName}"
  }
}