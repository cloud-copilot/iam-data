  },
  "purchaseoption": {
    "key": "PurchaseOption",
    "arn": "arn:${Partition}:aws-marketplace:::catalog/${CatalogName}/purchaseOption/${PurchaseOptionId}"
  },
  "dashboard": {
    "key": "Dashboard",
    "arn": "arn:${Partition}:aws-marketplace::${Account}:${Catalog}/ReportingData/${FactTable}/Dashboard/${DashboardName}"
  },
  "sellerdashboard": {
    "key": "SellerDashboard",
    "arn": "arn:${Partition}:aws-marketplace::${Account}:${Catalog}/ReportingData/${FactTable}/Dashboard/${DashboardName}"
