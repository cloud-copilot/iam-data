    "key": "Assessment",
    "arn": "arn:${Partition}:aws-marketplace:${Region}::${Catalog}/Assessment/${ResourceId}"
  },
  "changeset": {
    "key": "ChangeSet",
    "arn": "arn:${Partition}:aws-marketplace:${Region}:${Account}:${Catalog}/ChangeSet/${ResourceId}",
    "conditionKeys": [
      "aws:ResourceTag/${TagKey}",
      "catalog:ChangeType"
    ]
  },
  "entity": {
    "key": "Entity",
    "arn": "arn:${Partition}:aws-marketplace:${Region}:${Account}:${Catalog}/${EntityType}/${ResourceId}",
    "conditionKeys": [
      "aws:ResourceTag/${TagKey}",
      "catalog:ChangeType"
    ]
  },
  "invoicesubmissiontask": {
    "key": "InvoiceSubmissionTask",
    "arn": "arn:${Partition}:aws-marketplace:${Region}:${Account}:catalog/${Catalog}/invoice-submission-task/${ResourceId}",
    "conditionKeys": [
      "aws:ResourceTag/${TagKey}"
    ]
  },
  "issuedtaxinvoice": {
    "key": "IssuedTaxInvoice",
    "arn": "arn:${Partition}:aws-marketplace:${Region}:${Account}:catalog/${Catalog}/issued-tax-invoice/${ResourceId}",
    "conditionKeys": [
      "aws:ResourceTag/${TagKey}"
    ]
  },
  "verificationevidence": {
    "key": "VerificationEvidence",
