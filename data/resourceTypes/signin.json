{
  "console": {
    "key": "console",
    "arn": "arn:${Partition}:signin:::console/${ConsoleName}"
  },
  "oauth2-public-client-localhost": {
    "key": "oauth2-public-client-localhost",
    "arn": "arn:${Partition}:signin:${Region}:${Account}:oauth2/public-client/localhost"
  },
  "oauth2-public-client-registration": {
    "key": "oauth2-public-client-registration",
    "arn": "arn:${Partition}:signin:${Region}::external-client/dcr/*"
  },
  "oauth2-public-client-remote": {
    "key": "oauth2-public-client-remote",
    "arn": "arn:${Partition}:signin:${Region}:${Account}:oauth2/public-client/remote"
  },
  "oauth2-resource-service-principal": {
    "key": "oauth2-resource-service-principal",
    "arn": "arn:${Partition}:signin:${Region}:${Account}:service-principal/${ServicePrincipalName}"
  }
}